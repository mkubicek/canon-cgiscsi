FROM python:3.12-slim

WORKDIR /app

RUN python -m pip install --no-cache-dir defusedxml img2pdf pillow zeroconf

COPY airscan_adapter ./airscan_adapter
COPY harness ./harness

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app
VOLUME ["/scans"]

EXPOSE 8080
CMD ["python", "-m", "airscan_adapter.server", "--mock", "--bind", "0.0.0.0", "--port", "8080", "--allow-lan-bind"]
